# Copy this file to .env for local development (never commit .env).
# In GitHub Actions, set these as repository secrets (Settings → Secrets → Actions).

# Optional — enables Tier 1/2 LLM extraction via OpenRouter.
# Without this key the pipeline runs in Tier 0 (deterministic fallback) and
# still produces a fully populated dashboard.
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=
